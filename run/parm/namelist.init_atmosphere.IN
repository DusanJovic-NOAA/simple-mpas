&nhyd_model
    config_init_case = ${INIT_CASE}
    config_start_time = '${START_YEAR}-${START_MONTH}-${START_DAY}_${START_HOUR}:00:00'
    config_stop_time = '${STOP_YEAR}-${STOP_MONTH}-${STOP_DAY}_${STOP_HOUR}:00:00'
    config_theta_adv_order = 3
    config_coef_3rd_order = 0.25
    config_interface_projection = 'linear_interpolation'
/
&dimensions
    config_nvertlevels = 55
    config_nsoillevels = 4
    config_nfglevels = 38
    config_nfgsoillevels = 4
    config_gocartlevels = 30
/
&data_sources
    config_geog_data_path = '${GEOG_DATA_PATH}'
    config_met_prefix = 'GFS'
    config_sfc_prefix = 'GFS'
    config_fg_interval = ${FG_INTERVAL:-86400}
    config_landuse_data = 'MODIFIED_IGBP_MODIS_NOAH'
    config_soilcat_data = 'STATSGO'
    config_topo_data = 'GMTED2010'
    config_vegfrac_data = 'MODIS'
    config_albedo_data = 'MODIS'
    config_maxsnowalbedo_data = 'MODIS'
    config_supersample_factor = 3
    config_lu_supersample_factor = 1
    config_30s_supersample_factor = 1
    config_use_spechumd = false
/
&vertical_grid
    config_ztop = 30000.0
    config_nsmterrain = 1
    config_smooth_surfaces = true
    config_dzmin = 0.3
    config_nsm = 30
    config_tc_vertical_grid = true
    config_blend_bdy_terrain = ${BLEND_BDY_TERRAIN:-false}
/
&interpolation_control
    config_extrap_airtemp = 'lapse-rate'
/
&preproc_stages
    config_static_interp = ${CONFIG_STATIC_INTERP:-false}
    config_native_gwd_static = ${CONFIG_NATIVE_GWD_STATIC:-false}
    config_native_gwd_gsl_static = false
    config_vertical_grid = ${CONFIG_VERTICAL_GRID:-false}
    config_met_interp = ${CONFIG_MET_INTERP:-false}
    config_input_sst = ${CONFIG_INPUT_SST:-false}
    config_frac_seaice = ${CONFIG_FRAC_SEAICE:-false}
/
&io
    config_pio_num_iotasks = 0
    config_pio_stride = 1
/
&decomposition
    config_block_decomp_file_prefix = '${MGRID}.graph.info.part.'
/
